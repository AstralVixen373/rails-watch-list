<div class="banner">
  <div class="container">
    <h1>Movie Watch Lists</h1>
    <p>Create and manage your favorite movies.</p>
  </div>
</div>

<div class="container mt-4">
  <h2>My Lists</h2>
  <%= link_to "Create a movie list", new_list_path, class: "btn btn-primary mb-3" %>
  <div class="cards">
    <% @lists.each do |list| %>
      <div class="card-category">
        <%= link_to list.name, list_path(list) %>
      </div>
    <% end %>
  </div>
</div>
